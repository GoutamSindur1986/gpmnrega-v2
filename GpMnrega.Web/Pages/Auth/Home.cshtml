    @* GP config data-island: type="application/json" is NOT executed by the browser,
       it is a read-only data carrier. gphome.js reads it via JSON.parse on DOMContentLoaded.
       JsonSerializer handles all escaping (apostrophes, Unicode, etc.) — no manual Replace needed. *@
    <script type="application/json" id="gp-home-config">
        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new {
            gpCode               = panchayatCode,
            userEmail            = userEmail,
            userName             = userName,
            gpName               = gpName,
            gpNameRegional       = gpNameRegional,
            districtName         = districtName,
            districtCode         = districtCode,
            districtNameRegional = districtNameRegional,
            blockName            = blockName,
            blockCode            = blockCode,
            blockNameRegional    = blockNameRegional,
            vidhanSabha          = vidhanSabha,
            lokSabha             = lokSabha
        }))
        </script>
}