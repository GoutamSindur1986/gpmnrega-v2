<script>
var _progressTimer = null;
var _progressPct   = 0;

// Show progress overlay — fixed center popup with animated ring
function showDownloadProgress(label, sub) {
  document.getElementById('progressLabel').textContent = label || 'Generating PDF…';
  document.getElementById('progressSub').textContent   = sub   || 'Please wait';
  document.getElementById('downloadOverlay').classList.add('show');
  document.getElementById('downloadProgress').classList.add('show');
  _progressPct = 0;
  animateRing(0);
  if (_progressTimer) clearInterval(_progressTimer);
  _progressTimer = setInterval(function () {
    if (_progressPct < 90) {
      _progressPct += (90 - _progressPct) * 0.03;
      animateRing(_progressPct);
    }
  }, 600);
}

// Hide progress overlay — snap to 100% then close
function hideDownloadProgress() {
  if (_progressTimer) { clearInterval(_progressTimer); _progressTimer = null; }
  animateRing(100);
  setTimeout(function () {
    document.getElementById('downloadProgress').classList.remove('show');
    document.getElementById('downloadOverlay').classList.remove('show');
    _progressPct = 0;
  }, 600);
}

function animateRing(pct) {
  var ring = document.getElementById('progressRing');
  if (!ring) return;
  var circumference = 157; // 2 * π * r  where r=25
  ring.style.strokeDashoffset = circumference - (circumference * pct / 100);
}

// Load button — not used for PDF generation, kept for compatibility
function loadCashbook() {
  reportData.fincialYear = document.getElementById('ddlyear').value;
  gpToast('Financial year set to ' + reportData.fincialYear, 'info');
}
</script>
