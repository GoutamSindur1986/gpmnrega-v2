    @* Read the same auth claims that Home.cshtml injects — needed by common.js loadData() *@
    var cb_panchayatCode        = User.FindFirst("PanchayatCode")?.Value ?? "";
    var cb_panchayatName        = User.FindFirst("PanchyatName")?.Value ?? "";
    var cb_panchayatNameRegional= User.FindFirst("PanchayatNameRegional")?.Value ?? "";
    var cb_districtName         = User.FindFirst("DistrictName")?.Value ?? "";
    var cb_districtCode         = User.FindFirst("DistrictCode")?.Value ?? "";
    var cb_districtNameRegional = User.FindFirst("DistrictNameRegional")?.Value ?? "";
    var cb_blockName            = User.FindFirst("TalukName")?.Value ?? "";
    var cb_blockCode            = User.FindFirst("TalukCode")?.Value ?? "";
    var cb_blockNameRegional    = User.FindFirst("TalukNameRegional")?.Value ?? "";
    var cb_stateName            = User.FindFirst("StateName")?.Value ?? "KARNATAKA";
    var cb_stateCode            = User.FindFirst("StateCode")?.Value ?? "15";
    var cb_stateShortName       = User.FindFirst("short_name")?.Value ?? "";
    var cb_stateNameRegional    = User.FindFirst("StateNameRegional")?.Value ?? "";
    var cb_userName             = User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "";
    var cb_vidhanSabha          = User.FindFirst("VidhanSabha")?.Value ?? "";
    var cb_lokSabha             = User.FindFirst("LokSabha")?.Value ?? "";
    var cb_isSubscribed         = User.FindFirst("IsSubscribed")?.Value == "true";
}
@* GP data island — read by common.js loadData() on DOMContentLoaded *@
<script type="application/json" id="gp-home-config">
    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new {
        panchayat_code         = cb_panchayatCode,
        panchayatName          = cb_panchayatName,
        panchayat_NameRegional = cb_panchayatNameRegional,
        districtName           = cb_districtName,
        district_code          = cb_districtCode,
        districtNameRegional   = cb_districtNameRegional,
        blockName              = cb_blockName,
        block_code             = cb_blockCode,
        blockNameRegional      = cb_blockNameRegional,
        stateName              = cb_stateName,
        state_code             = cb_stateCode,
        state_shortname        = cb_stateShortName,
        stateNameRegional      = cb_stateNameRegional,
        userName               = cb_userName,
        vidhanSabha            = cb_vidhanSabha,
        lokSabha               = cb_lokSabha,
        isSubscribed           = cb_isSubscribed
    }))
</script>

