@page "/Offers"
@model GpMnrega.Web.Pages.OffersModel
@{
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Offers & Products";
}

<style>
.offers-hero{
  background:linear-gradient(135deg,#1e1b6e,#3730a3,#4f46e5);
  color:#fff;padding:48px 0 36px;margin:-24px -15px 0;
}
.offers-hero h1{font-size:clamp(1.6rem,3vw,2.2rem);font-weight:800;margin-bottom:8px}
.offers-hero p{opacity:.85;font-size:.92rem;max-width:560px;margin:0 auto}
.offer-card{
  background:#fff;border:1px solid #e2e8f0;border-radius:16px;
  overflow:hidden;transition:all .2s;height:100%;display:flex;flex-direction:column;
}
.offer-card:hover{box-shadow:0 12px 40px rgba(55,48,163,.1);transform:translateY(-3px)}
.offer-card-header{padding:24px 24px 16px;flex-shrink:0}
.offer-card-body{padding:0 24px 20px;flex:1;display:flex;flex-direction:column}
.offer-card-footer{padding:16px 24px;border-top:1px solid #f1f5f9;flex-shrink:0}
.offer-badge{
  display:inline-flex;align-items:center;gap:5px;
  font-size:.7rem;font-weight:700;letter-spacing:.07em;text-transform:uppercase;
  padding:3px 10px;border-radius:20px;margin-bottom:12px;
}
.badge-live{background:#d1fae5;color:#065f46}
.badge-soon{background:#fef3c7;color:#92400e}
.badge-sponsor{background:#dbeafe;color:#1e40af}
.offer-icon{
  width:52px;height:52px;border-radius:13px;
  display:flex;align-items:center;justify-content:center;
  font-size:1.4rem;margin-bottom:14px;
}
.offer-title{font-size:1.05rem;font-weight:700;color:#1e1b6e;margin-bottom:6px}
.offer-desc{font-size:.86rem;color:#64748b;line-height:1.7;flex:1}
.offer-link{
  display:inline-flex;align-items:center;gap:6px;
  font-size:.84rem;font-weight:600;color:#3730a3;text-decoration:none;
  padding:9px 18px;border:1.5px solid #c4b5fd;border-radius:9px;
  background:#f5f3ff;transition:all .15s;width:100%;justify-content:center;
}
.offer-link:hover{background:#3730a3;color:#fff;border-color:#3730a3}
.offer-link.disabled{color:#94a3b8;border-color:#e2e8f0;background:#f8faff;pointer-events:none}
.section-label{
  font-size:.72rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;
  color:#94a3b8;margin-bottom:20px;padding-bottom:10px;border-bottom:1px solid #f1f5f9;
}
.coming-soon-strip{
  background:linear-gradient(135deg,#fef3c7,#fff7ed);
  border:1px solid #fde68a;border-radius:14px;padding:20px 24px;
  display:flex;align-items:center;gap:16px;margin-bottom:32px;
}
.notify-form{display:flex;gap:10px;flex-wrap:wrap;margin-top:10px}
.notify-form input{
  flex:1;min-width:200px;padding:9px 14px;
  border:1.5px solid #e2e8f0;border-radius:9px;font-size:.85rem;
  font-family:'Poppins',sans-serif;outline:none;
}
.notify-form input:focus{border-color:#4f46e5;box-shadow:0 0 0 3px rgba(79,70,229,.08)}
.notify-form button{
  padding:9px 20px;background:#3730a3;color:#fff;border:none;border-radius:9px;
  font-size:.85rem;font-weight:600;cursor:pointer;font-family:'Poppins',sans-serif;
  white-space:nowrap;
}
.notify-form button:hover{background:#4f46e5}
</style>

<div class="offers-hero text-center">
  <div class="container">
    <h1><i class="bi bi-lightning-fill me-2" style="color:#fbbf24"></i>Offers &amp; Products</h1>
    <p>Explore GP MNREGA plans and upcoming products from S3KN Software Solutions.</p>
  </div>
</div>

<div class="container py-4">

  <!-- Coming soon notification strip -->
  <div class="coming-soon-strip">
    <i class="bi bi-bell-fill" style="font-size:2rem;color:#f59e0b;flex-shrink:0"></i>
    <div style="flex:1">
      <div style="font-weight:700;color:#92400e;font-size:.93rem;margin-bottom:4px">New products launching soon!</div>
      <div style="font-size:.83rem;color:#78350f">WhatsApp, Instagram, Facebook &amp; WebChat automation tools are in development. Enter your email to get notified when they launch.</div>
      <div class="notify-form" id="notifyForm">
        <input type="email" id="notifyEmail" placeholder="Enter your email address"/>
        <button onclick="submitNotify()"><i class="bi bi-bell me-1"></i>Notify Me</button>
      </div>
      <div id="notifyMsg" style="display:none;font-size:.82rem;color:#059669;margin-top:8px;font-weight:600">
        <i class="bi bi-check-circle-fill me-1"></i>You are on the list! We will notify you at launch.
      </div>
    </div>
  </div>

  <!-- GP MNREGA Plans -->
  <div class="section-label"><i class="bi bi-flower1 me-1"></i>GP MNREGA — Active Plans</div>
  <div class="row g-4 mb-5">

    <div class="col-md-4">
      <div class="offer-card">
        <div class="offer-card-header">
          <span class="offer-badge badge-live"><i class="bi bi-check-circle-fill"></i>Free Trial</span>
          <div class="offer-icon" style="background:#f0fdf4"><i class="bi bi-flower1" style="color:#059669"></i></div>
          <div class="offer-title">GP MNREGA Trial</div>
        </div>
        <div class="offer-card-body">
          <p class="offer-desc">Full access to all report types with watermarked PDFs. No time limit — evaluate as long as you need before subscribing.</p>
        </div>
        <div class="offer-card-footer">
          <div style="font-size:1.5rem;font-weight:800;color:#059669;margin-bottom:10px">Free</div>
          <a href="/Auth/PaySub" class="offer-link" style="background:#f0fdf4;border-color:#bbf7d0;color:#065f46">
            <i class="bi bi-play-fill"></i> Currently Active
          </a>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="offer-card" style="border-color:#c4b5fd">
        <div class="offer-card-header">
          <span class="offer-badge" style="background:#ede9fe;color:#4c1d95"><i class="bi bi-star-fill"></i>Most Popular</span>
          <div class="offer-icon" style="background:#ede9fe"><i class="bi bi-star-fill" style="color:#7c3aed"></i></div>
          <div class="offer-title">GP MNREGA Yearly</div>
        </div>
        <div class="offer-card-body">
          <p class="offer-desc">Full access, no watermarks, priority support. All report types — Form 6, Form 8, Form 9, Cashbook, Registers and more.</p>
          <ul style="font-size:.82rem;color:#64748b;padding-left:16px;margin-top:10px">
            <li>Unlimited PDF downloads</li>
            <li>Kannada regional name support</li>
            <li>Priority email support</li>
          </ul>
        </div>
        <div class="offer-card-footer">
          <div style="font-size:1.5rem;font-weight:800;color:#3730a3;margin-bottom:10px">₹799 <span style="font-size:.85rem;font-weight:400;color:#64748b">/ year</span></div>
          <a href="/Auth/PaySub" class="offer-link">
            <i class="bi bi-lightning-fill"></i> Subscribe Now
          </a>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="offer-card">
        <div class="offer-card-header">
          <span class="offer-badge" style="background:#dbeafe;color:#1e40af"><i class="bi bi-shield-fill"></i>Best Value</span>
          <div class="offer-icon" style="background:#dbeafe"><i class="bi bi-shield-fill" style="color:#1d4ed8"></i></div>
          <div class="offer-title">GP MNREGA 3-Year</div>
        </div>
        <div class="offer-card-body">
          <p class="offer-desc">Maximum savings with 3 years of full access. Lock in the current price and never worry about renewals.</p>
          <ul style="font-size:.82rem;color:#64748b;padding-left:16px;margin-top:10px">
            <li>Everything in Yearly plan</li>
            <li>Save over ₹500 vs monthly</li>
            <li>Price locked for 3 years</li>
          </ul>
        </div>
        <div class="offer-card-footer">
          <div style="font-size:1.5rem;font-weight:800;color:#1d4ed8;margin-bottom:10px">₹1,999 <span style="font-size:.85rem;font-weight:400;color:#64748b">/ 3 years</span></div>
          <a href="/Auth/PaySub" class="offer-link" style="background:#eff6ff;border-color:#bfdbfe;color:#1d4ed8">
            <i class="bi bi-lightning-fill"></i> Subscribe Now
          </a>
        </div>
      </div>
    </div>

  </div>

  <!-- Coming Soon Products -->
  <div class="section-label"><i class="bi bi-rocket-takeoff me-1"></i>Coming Soon — S3KN Products</div>
  <div class="row g-4 mb-4">

    <div class="col-md-6 col-lg-3">
      <div class="offer-card">
        <div class="offer-card-header">
          <span class="offer-badge badge-soon"><i class="bi bi-clock"></i>Coming Soon</span>
          <div class="offer-icon" style="background:#fef3c7"><i class="bi bi-whatsapp" style="color:#15803d"></i></div>
          <div class="offer-title">WhatsApp Automation</div>
        </div>
        <div class="offer-card-body">
          <p class="offer-desc">Auto-reply to WhatsApp messages, send bulk notifications, and manage customer conversations with AI.</p>
        </div>
        <div class="offer-card-footer">
          <a href="#notify" onclick="focusNotify()" class="offer-link disabled">
            <i class="bi bi-bell"></i> Notify Me at Launch
          </a>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-lg-3">
      <div class="offer-card">
        <div class="offer-card-header">
          <span class="offer-badge badge-soon"><i class="bi bi-clock"></i>Coming Soon</span>
          <div class="offer-icon" style="background:#fce7f3"><i class="bi bi-instagram" style="color:#9d174d"></i></div>
          <div class="offer-title">Instagram Automation</div>
        </div>
        <div class="offer-card-body">
          <p class="offer-desc">Schedule posts, auto-reply to DMs and comments, grow your Instagram following hands-free.</p>
        </div>
        <div class="offer-card-footer">
          <a href="#notify" onclick="focusNotify()" class="offer-link disabled">
            <i class="bi bi-bell"></i> Notify Me at Launch
          </a>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-lg-3">
      <div class="offer-card">
        <div class="offer-card-header">
          <span class="offer-badge badge-soon"><i class="bi bi-clock"></i>Coming Soon</span>
          <div class="offer-icon" style="background:#dbeafe"><i class="bi bi-facebook" style="color:#1d4ed8"></i></div>
          <div class="offer-title">Facebook Automation</div>
        </div>
        <div class="offer-card-body">
          <p class="offer-desc">Manage Facebook pages, auto-respond to comments and messages, and track engagement at scale.</p>
        </div>
        <div class="offer-card-footer">
          <a href="#notify" onclick="focusNotify()" class="offer-link disabled">
            <i class="bi bi-bell"></i> Notify Me at Launch
          </a>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-lg-3">
      <div class="offer-card">
        <div class="offer-card-header">
          <span class="offer-badge badge-soon"><i class="bi bi-clock"></i>Coming Soon</span>
          <div class="offer-icon" style="background:#d1fae5"><i class="bi bi-chat-dots-fill" style="color:#047857"></i></div>
          <div class="offer-title">WebChat Automation</div>
        </div>
        <div class="offer-card-body">
          <p class="offer-desc">AI-powered live chat widget for your website. Auto-respond to visitors, capture leads 24/7.</p>
        </div>
        <div class="offer-card-footer">
          <a href="#notify" onclick="focusNotify()" class="offer-link disabled">
            <i class="bi bi-bell"></i> Notify Me at Launch
          </a>
        </div>
      </div>
    </div>

  </div>

  <!-- Advertise slot -->
  <div class="p-4 rounded-3" style="background:linear-gradient(135deg,#1e1b6e,#3730a3);color:#fff">
    <div class="row align-items-center g-3">
      <div class="col-md-8">
        <h5 style="font-weight:700;margin-bottom:6px"><i class="bi bi-megaphone-fill me-2" style="color:#fbbf24"></i>Advertise on GP MNREGA</h5>
        <p style="opacity:.85;font-size:.88rem;margin:0">Reach 1,500+ active Gram Panchayat officials across Karnataka every day. Contact us to discuss ad placement, pricing, and sponsorship opportunities.</p>
      </div>
      <div class="col-md-4 text-md-end">
        <a href="/contact" class="btn" style="background:#fff;color:#3730a3;font-weight:700;border-radius:10px;padding:10px 24px">
          <i class="bi bi-envelope me-1"></i> Contact Us
        </a>
      </div>
    </div>
  </div>

</div>

<script>
function focusNotify() {
  document.getElementById('notifyEmail').focus();
  document.getElementById('notifyEmail').scrollIntoView({behavior:'smooth',block:'center'});
}
function submitNotify() {
  var email = document.getElementById('notifyEmail').value.trim();
  var re = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
  if (!email || !re.test(email)) {
    document.getElementById('notifyEmail').style.borderColor='#ef4444';
    return;
  }
  document.getElementById('notifyForm').style.display='none';
  document.getElementById('notifyMsg').style.display='block';
  // POST to /api/contact/notify when that endpoint exists
  fetch('/api/contact/notify', {
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({email:email, interest:'product-launch'})
  }).catch(()=>{});
}
</script>
