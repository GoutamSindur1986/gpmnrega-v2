            <div class="kv-row"><span class="kv-label">Type</span><span class="kv-val">Private Limited</span></div>
            <div class="kv-row"><span class="kv-label">HQ</span><span class="kv-val">Mysuru, Karnataka</span></div>
            <div class="kv-row"><span class="kv-label">Industry</span><span class="kv-val">IT Products &amp; Services</span></div>
            <div class="kv-row"><span class="kv-label">Email</span><span class="kv-val"><a href="mailto:admin@gpmnrega.com" style="color:#3730a3">admin@@gpmnrega.com</a></span></div>
            <div class="kv-row"><span class="kv-label">Address</span><span class="kv-val">SY 953/*/P2 107, Sai Park Ring Road, Vijayapur 586109</span></div>
          </div>
        </div>
      </div>
      <h5 style="font-weight:700;color:#1e1b6e;margin-bottom:14px">Products &amp; Services</h5>
      <div class="row g-3">
        <div class="col-md-6 col-lg-3"><div class="feature-card"><div class="d-flex align-items-center gap-2 mb-2"><div class="sec-icon" style="background:#ede9fe"><i class="bi bi-flower1" style="color:#7c3aed"></i></div><div><div style="font-weight:700;font-size:.88rem;color:#1e1b6e">GP MNREGA</div><span class="badge" style="background:#d1fae5;color:#15803d;font-size:.7rem">Live</span></div></div><p style="font-size:.8rem;color:#64748b;margin:0">NREGA report platform for Karnataka GPs</p></div></div>
        <div class="col-md-6 col-lg-3"><div class="feature-card"><div class="d-flex align-items-center gap-2 mb-2"><div class="sec-icon" style="background:#dbeafe"><i class="bi bi-chat-dots-fill" style="color:#1d4ed8"></i></div><div><div style="font-weight:700;font-size:.88rem;color:#1e1b6e">WebChat Automation</div><span class="badge" style="background:#fef3c7;color:#92400e;font-size:.7rem">Coming Soon</span></div></div><p style="font-size:.8rem;color:#64748b;margin:0">AI-powered WhatsApp, Web &amp; SMS automation</p></div></div>
        <div class="col-md-6 col-lg-3"><div class="feature-card"><div class="d-flex align-items-center gap-2 mb-2"><div class="sec-icon" style="background:#fce7f3"><i class="bi bi-instagram" style="color:#9d174d"></i></div><div><div style="font-weight:700;font-size:.88rem;color:#1e1b6e">Instagram Automation</div><span class="badge" style="background:#fef3c7;color:#92400e;font-size:.7rem">Coming Soon</span></div></div><p style="font-size:.8rem;color:#64748b;margin:0">Auto-reply DMs, schedule posts, grow followers</p></div></div>
