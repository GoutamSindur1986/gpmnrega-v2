@page "/about"
@{
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "About Us";
}

<style>
.page-hero{background:linear-gradient(135deg,#1e1b6e 0%,#3730a3 60%,#4f46e5 100%);color:#fff;padding:56px 0 40px;position:relative;overflow:hidden;margin:-24px -15px 0}
.page-hero h1{font-size:clamp(2rem,4vw,2.6rem);font-weight:800;margin-bottom:10px;position:relative}
.hero-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.25);border-radius:24px;padding:6px 16px;font-size:.82rem;font-weight:500;margin-bottom:18px;position:relative}
.about-tabs{background:#fff;border-bottom:1px solid #e2e8f0;position:sticky;top:60px;z-index:40;margin:-8px -15px 0}
.about-tabs .nav-link{font-size:.9rem;font-weight:500;color:#64748b;border:none;border-bottom:3px solid transparent;border-radius:0;padding:14px 20px;transition:all .15s}
.about-tabs .nav-link.active,.about-tabs .nav-link:hover{color:#3730a3;border-bottom-color:#3730a3;background:none}
.stat-num{font-size:2.2rem;font-weight:800;color:#3730a3;line-height:1}
.stat-label{font-size:.82rem;color:#64748b;margin-top:4px}
.feature-card{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:20px;height:100%;transition:all .2s}
.feature-card:hover{box-shadow:0 6px 24px rgba(55,48,163,.08);transform:translateY(-2px)}
.sec-icon{width:44px;height:44px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0}
.kv-row{display:flex;padding:9px 0;border-bottom:1px solid #f1f5f9;font-size:.87rem}
.kv-row:last-child{border-bottom:none}
.kv-label{font-weight:600;color:#374151;min-width:130px}
.kv-val{color:#64748b}
</style>

<div class="page-hero text-center">
  <div class="container">
    <div class="hero-badge"><i class="bi bi-flower1"></i> GP MNREGA — Karnataka's Gram Panchayat Reporting Platform</div>
    <h1>Empowering Gram Panchayats<br/>across Karnataka</h1>
    <p style="opacity:.85;font-size:.95rem;max-width:540px;margin:0 auto">Making NREGA work reporting simple, accurate and accessible for every GP officer.</p>
  </div>
</div>

<div class="bg-white border-bottom mb-0">
  <div class="container">
    <div class="row g-0 text-center">
      <div class="col-6 col-md-3 border-end"><div class="py-4"><div class="stat-num">1500+</div><div class="stat-label">Registered GPs</div></div></div>
      <div class="col-6 col-md-3 border-end"><div class="py-4"><div class="stat-num">2021</div><div class="stat-label">Founded</div></div></div>
      <div class="col-6 col-md-3 border-end"><div class="py-4"><div class="stat-num">21+</div><div class="stat-label">Report Types</div></div></div>
      <div class="col-6 col-md-3"><div class="py-4"><div class="stat-num">99.9%</div><div class="stat-label">Uptime SLA</div></div></div>
    </div>
  </div>
</div>

<div class="about-tabs">
  <div class="container">
    <ul class="nav" id="aboutTabs" role="tablist">
      <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-gp">GP MNREGA Platform</button></li>
      <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-s3kn">About S3KN Software</button></li>
      <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-compliance">Compliance &amp; Security</button></li>
    </ul>
  </div>
</div>

<div class="container py-4">
  <div class="tab-content">

    <!-- Tab 1: GP MNREGA -->
    <div class="tab-pane fade show active" id="tab-gp">
      <div class="row g-4 mb-4">
        <div class="col-lg-6">
          <h2 style="font-size:1.5rem;font-weight:700;color:#1e1b6e;margin-bottom:14px">What is GP MNREGA?</h2>
          <p style="color:#64748b;line-height:1.8;font-size:.93rem">
            <strong style="color:#374151">www.gpmnrega.com</strong> is a reporting platform for Karnataka Gram Panchayat officers — PDOs, computer operators, and members — to generate official MGNREGA work reports quickly and accurately.
          </p>
          <p style="color:#64748b;line-height:1.8;font-size:.93rem">
            The platform uses publicly available data from the <a href="https://nrega.nic.in" target="_blank" rel="noopener" style="color:#3730a3">MGNREGA portal</a> and combines it with your inputs to produce print-ready, Kannada-localised PDFs.
          </p>
          <div class="p-3 rounded-3 mt-3" style="background:#ede9fe;border:1px solid #c4b5fd">
            <div class="d-flex gap-2 align-items-start">
              <i class="bi bi-info-circle-fill" style="color:#3730a3;margin-top:2px;flex-shrink:0"></i>
              <small style="color:#4c1d95">GP MNREGA is not affiliated with or endorsed by MGNREGA, NIC, or any Government of India body. All government data used is publicly available.</small>
            </div>
          </div>
          <div class="mt-4 p-3 rounded-3" style="background:#fff;border:1px solid #e2e8f0">
            <h6 style="font-weight:700;color:#1e1b6e;margin-bottom:14px"><i class="bi bi-arrow-right-circle-fill me-2" style="color:#3730a3"></i>How It Works</h6>
            <div class="row g-2 text-center">
              <div class="col-6"><div class="mx-auto mb-1 d-flex align-items-center justify-content-center rounded-circle" style="width:36px;height:36px;background:#3730a3;color:#fff;font-weight:700;font-size:.9rem">1</div><div style="font-weight:600;font-size:.82rem;color:#1e1b6e">Register</div><div style="font-size:.75rem;color:#94a3b8">GP code + email</div></div>
              <div class="col-6"><div class="mx-auto mb-1 d-flex align-items-center justify-content-center rounded-circle" style="width:36px;height:36px;background:#3730a3;color:#fff;font-weight:700;font-size:.9rem">2</div><div style="font-weight:600;font-size:.82rem;color:#1e1b6e">Search Work Code</div><div style="font-size:.75rem;color:#94a3b8">We fetch NIC data automatically</div></div>
              <div class="col-6"><div class="mx-auto mb-1 d-flex align-items-center justify-content-center rounded-circle" style="width:36px;height:36px;background:#3730a3;color:#fff;font-weight:700;font-size:.9rem">3</div><div style="font-weight:600;font-size:.82rem;color:#1e1b6e">Generate Reports</div><div style="font-size:.75rem;color:#94a3b8">NIC data + your inputs</div></div>
              <div class="col-6"><div class="mx-auto mb-1 d-flex align-items-center justify-content-center rounded-circle" style="width:36px;height:36px;background:#3730a3;color:#fff;font-weight:700;font-size:.9rem">4</div><div style="font-weight:600;font-size:.82rem;color:#1e1b6e">Download &amp; Print</div><div style="font-size:.75rem;color:#94a3b8">Print-ready Kannada PDFs</div></div>
            </div>
          </div>
        </div>
        <div class="col-lg-6">
          <div class="row g-3">
            <div class="col-6"><div class="feature-card"><div class="sec-icon mb-2" style="background:#ede9fe"><i class="bi bi-file-earmark-text-fill" style="color:#7c3aed"></i></div><div style="font-weight:600;font-size:.85rem;color:#1e1b6e;margin-bottom:3px">Cover Page &amp; Work Order</div><div style="font-size:.77rem;color:#94a3b8">Auto-generated with GP details and NIC data</div></div></div>
            <div class="col-6"><div class="feature-card"><div class="sec-icon mb-2" style="background:#dbeafe"><i class="bi bi-people-fill" style="color:#1d4ed8"></i></div><div style="font-weight:600;font-size:.85rem;color:#1e1b6e;margin-bottom:3px">Form 6 — Work Application</div><div style="font-size:.77rem;color:#94a3b8">Group and Individual registers</div></div></div>
