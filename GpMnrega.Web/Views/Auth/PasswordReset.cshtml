@{
    Layout = null;
    var email = ViewBag.Email as string ?? "";
    var hasToken = !string.IsNullOrEmpty(ViewBag.Token as string);
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Reset Password — GP MNREGA</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
<style>
body{font-family:'Poppins',sans-serif;background:#f0f4ff;
  min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px}
.card-wrap{
  background:#fff;border-radius:20px;padding:48px 40px;
  max-width:420px;width:100%;
  box-shadow:0 8px 40px rgba(55,48,163,.1);
}
.logo{display:flex;align-items:center;gap:10px;margin-bottom:32px;justify-content:center}
.logo-mark{
  width:38px;height:38px;border-radius:9px;
  background:linear-gradient(135deg,#3730a3,#4f46e5);
  display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.1rem;
}
h2{font-size:1.35rem;font-weight:700;color:#1e1b6e;margin-bottom:6px}
.sub{font-size:.85rem;color:#64748b;margin-bottom:24px}

.inp-wrap{position:relative;margin-bottom:16px}
.inp-wrap i.ic{
  position:absolute;left:13px;top:50%;transform:translateY(-50%);
  color:#94a3b8;font-size:.95rem;pointer-events:none;
}
.inp-wrap input{
  width:100%;padding:11px 14px 11px 38px;
  border:1.5px solid #e2e8f0;border-radius:10px;
  font-size:.9rem;font-family:'Poppins',sans-serif;
  background:#f8faff;outline:none;transition:all .2s;
}
.inp-wrap input:focus{border-color:#4f46e5;background:#fff;box-shadow:0 0 0 3px rgba(79,70,229,.1)}
.pw-eye{
  position:absolute;right:12px;top:50%;transform:translateY(-50%);
  cursor:pointer;color:#94a3b8;background:none;border:none;font-size:1rem;
}
.field-err{color:#ef4444;font-size:.78rem;margin-top:-10px;margin-bottom:10px;display:none}
.field-err.show{display:block}
.btn-main{
  width:100%;padding:12px;
  background:linear-gradient(135deg,#3730a3,#4f46e5);
  color:#fff;border:none;border-radius:10px;
  font-size:.95rem;font-weight:600;cursor:pointer;
  transition:all .2s;display:flex;align-items:center;justify-content:center;gap:8px;
}
.btn-main:hover{filter:brightness(1.1)}
.msg-box{
  padding:12px 16px;border-radius:10px;font-size:.85rem;
  display:flex;align-items:flex-start;gap:10px;margin-bottom:16px;
}
.msg-success{background:#f0fdf4;border:1px solid #bbf7d0;color:#15803d}
.msg-error{background:#fef2f2;border:1px solid #fecaca;color:#b91c1c}
.back-link{
  text-align:center;margin-top:20px;font-size:.83rem;color:#94a3b8;
}
.back-link a{color:#4f46e5;font-weight:500;text-decoration:none}
</style>
</head>
<body>
<div class="card-wrap">

  <div class="logo">
    <div class="logo-mark"><i class="bi bi-flower1"></i></div>
    <span style="font-size:1.1rem;font-weight:700;color:#1e1b6e">GP MNREGA</span>
  </div>

  <div id="msgBox" style="display:none"></div>

  @if (hasToken)
  {
    <!-- Step 2: Set new password -->
    <h2>Set New Password</h2>
    <p class="sub">Enter your new password for <strong>@email</strong></p>

    <form id="resetForm" novalidate>
      <div class="inp-wrap">
        <i class="bi bi-lock ic"></i>
        <input type="password" id="newPassword" placeholder="New password (6–15 chars)"/>
        <button type="button" class="pw-eye" onclick="togglePw('newPassword',this)">
          <i class="bi bi-eye-slash"></i>
        </button>
      </div>
      <div id="pwErr" class="field-err"></div>

      <div class="inp-wrap">
        <i class="bi bi-lock-fill ic"></i>
        <input type="password" id="confirmPassword" placeholder="Confirm new password"/>
      </div>
      <div id="cpwErr" class="field-err"></div>

      <button type="submit" class="btn-main">
        <i class="bi bi-check-lg"></i> Update Password
      </button>
    </form>

    <script>
    document.getElementById('resetForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      var pw = document.getElementById('newPassword').value;
      var cpw = document.getElementById('confirmPassword').value;
      var valid = true;

      document.getElementById('pwErr').classList.remove('show');
      document.getElementById('cpwErr').classList.remove('show');

      if (!pw || pw.length < 6 || pw.length > 15 || pw.includes(' ')) {
        document.getElementById('pwErr').textContent = 'Password: 6–15 characters, no spaces';
        document.getElementById('pwErr').classList.add('show');
        valid = false;
      }
      if (pw !== cpw) {
        document.getElementById('cpwErr').textContent = 'Passwords do not match';
        document.getElementById('cpwErr').classList.add('show');
        valid = false;
      }
      if (!valid) return;

      var btn = this.querySelector('.btn-main');
      btn.disabled = true; btn.textContent = 'Updating…';

      var fd = new FormData();
      fd.append('email', '@email');
      fd.append('newPassword', pw);

      var resp = await fetch('/api/auth/reset-password', { method: 'POST', body: fd });
      var data = await resp.json();
      var box = document.getElementById('msgBox');
      box.style.display = '';

      if (resp.ok) {
        box.className = 'msg-box msg-success';
        box.innerHTML = '<i class="bi bi-check-circle-fill"></i><span>' + data.message +
          ' <a href="/login" style="color:#15803d;font-weight:600">Sign in</a></span>';
        document.getElementById('resetForm').style.display = 'none';
      } else {
        box.className = 'msg-box msg-error';
        box.innerHTML = '<i class="bi bi-x-circle-fill"></i><span>' + (data.error || 'Reset failed') + '</span>';
        btn.disabled = false; btn.textContent = 'Update Password';
      }
    });

    function togglePw(id, btn) {
      var inp = document.getElementById(id);
      var ic = btn.querySelector('i');
      if (inp.type === 'password') { inp.type = 'text'; ic.className = 'bi bi-eye'; }
      else { inp.type = 'password'; ic.className = 'bi bi-eye-slash'; }
    }
    </script>
  }
  else
  {
    <!-- Step 1: Enter email -->
    <h2>Forgot Password?</h2>
    <p class="sub">Enter your email address and we'll send you a reset link.</p>

    <form id="forgotForm" novalidate>
      <div class="inp-wrap">
        <i class="bi bi-envelope ic"></i>
        <input type="email" id="forgotEmail" placeholder="Your email address"
               value="@email" autocomplete="email"/>
      </div>
      <div id="emailErr" class="field-err"></div>

      <button type="submit" class="btn-main">
        <i class="bi bi-send"></i> Send Reset Link
      </button>
    </form>

    <script>
    document.getElementById('forgotForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      var email = document.getElementById('forgotEmail').value.trim();
      document.getElementById('emailErr').classList.remove('show');

      if (!email || !/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email)) {
        document.getElementById('emailErr').textContent = 'Enter a valid email address';
        document.getElementById('emailErr').classList.add('show');
        return;
      }

      var btn = this.querySelector('.btn-main');
      btn.disabled = true; btn.innerHTML = '<span>Sending…</span>';

      // POST to password reset request endpoint
      var fd = new FormData();
      fd.append('email', email);
      var resp = await fetch('/api/auth/forgot-password', { method: 'POST', body: fd });
      var data = await resp.json();
      var box = document.getElementById('msgBox');
      box.style.display = '';
      box.className = 'msg-box ' + (resp.ok ? 'msg-success' : 'msg-error');
      box.innerHTML = '<i class="bi bi-' + (resp.ok ? 'check-circle-fill' : 'x-circle-fill') +
        '"></i><span>' + (data.message || data.error || 'Please try again.') + '</span>';

      if (resp.ok) this.style.display = 'none';
      else { btn.disabled = false; btn.innerHTML = '<i class="bi bi-send"></i> Send Reset Link'; }
    });
    </script>
  }

  <div class="back-link"><a href="/login">← Back to Login</a></div>

</div>
</body>
</html>
