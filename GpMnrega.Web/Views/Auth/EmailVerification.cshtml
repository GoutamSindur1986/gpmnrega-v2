@{
    Layout = null;
    var email = ViewBag.Email as string ?? "";
    var verified = ViewBag.Verified as bool? ?? false;
    var error = ViewBag.Error as string;
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Email Verification — GP MNREGA</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
<style>
body{font-family:'Poppins',sans-serif;background:#f0f4ff;
  min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px}
.card-wrap{
  background:#fff;border-radius:20px;padding:48px 40px;
  max-width:440px;width:100%;text-align:center;
  box-shadow:0 8px 40px rgba(55,48,163,.1);
}
.icon-circle{
  width:80px;height:80px;border-radius:50%;margin:0 auto 24px;
  display:flex;align-items:center;justify-content:center;font-size:2.2rem;
}
.icon-success{background:#d1fae5;color:#059669}
.icon-pending{background:#ede9fe;color:#7c3aed}
.icon-error{background:#fef2f2;color:#ef4444}
h2{font-size:1.4rem;font-weight:700;color:#1e1b6e;margin-bottom:8px}
p{font-size:.88rem;color:#64748b;margin-bottom:0}
.email-chip{
  display:inline-block;background:#f1f5f9;border-radius:20px;
  padding:4px 14px;font-size:.82rem;color:#3730a3;
  font-weight:600;margin:12px 0;
}
.btn-go{
  background:linear-gradient(135deg,#3730a3,#4f46e5);color:#fff;
  border:none;border-radius:10px;padding:11px 28px;
  font-size:.9rem;font-weight:600;cursor:pointer;
  text-decoration:none;display:inline-block;margin-top:20px;transition:all .2s;
}
.btn-go:hover{filter:brightness(1.1);color:#fff}
</style>
</head>
<body>
<div class="card-wrap">

  @if (verified)
  {
    <!-- Email verified successfully -->
    <div class="icon-circle icon-success">
      <i class="bi bi-check-circle-fill"></i>
    </div>
    <h2>Email Verified!</h2>
    <p>Your account has been activated successfully.</p>
    @if (!string.IsNullOrEmpty(email))
    {
      <span class="email-chip">@email</span>
    }
    <br/>
    <a href="/login" class="btn-go">Sign In Now</a>
  }
  else if (!string.IsNullOrEmpty(error))
  {
    <!-- Verification error -->
    <div class="icon-circle icon-error">
      <i class="bi bi-x-circle-fill"></i>
    </div>
    <h2>Verification Failed</h2>
    <p>@error</p>
    <p class="mt-2">The link may have expired or already been used.</p>
    <a href="/login" class="btn-go">Back to Login</a>
  }
  else
  {
    <!-- Awaiting verification - just registered -->
    <div class="icon-circle icon-pending">
      <i class="bi bi-envelope-fill"></i>
    </div>
    <h2>Check Your Email</h2>
    <p>We've sent a verification link to:</p>
    @if (!string.IsNullOrEmpty(email))
    {
      <span class="email-chip">@email</span>
    }
    <p class="mt-3">
      Click the link in the email to activate your account.<br/>
      <small style="color:#94a3b8">Check your spam folder if you don't see it.</small>
    </p>
    <a href="/login" class="btn-go" style="background:#f1f5f9;color:#3730a3;
       box-shadow:none;filter:none">Back to Login</a>
  }

</div>
</body>
</html>
